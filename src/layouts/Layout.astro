---
import "../styles/global.css";
import Analytics from "@vercel/analytics/astro";

interface Props {
  title?: string;
  description?: string;
  canonicalUrl?: string;
  robots?: string;
}

const {
  title = "climp - a minimal cli media player",
  description = "A minimal CLI media player. Written in Go.",
  canonicalUrl,
  robots,
} = Astro.props;

const siteOrigin = Astro.site?.origin ?? "https://climp.net";

const normalizePathname = (pathname: string) => {
  if (pathname !== "/" && pathname.endsWith("/")) {
    return pathname.slice(0, -1);
  }
  return pathname;
};

const buildCanonicalUrl = (input?: string) => {
  const source = input ?? Astro.url.pathname;
  const canonical = new URL(source, siteOrigin);
  canonical.pathname = normalizePathname(canonical.pathname);
  canonical.search = "";
  canonical.hash = "";
  return canonical.toString();
};

const canonical = buildCanonicalUrl(canonicalUrl);
const isProduction = import.meta.env.VERCEL_ENV === "production";
const robotsContent = robots ?? (isProduction ? "index,follow" : "noindex,nofollow");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="robots" content={robotsContent} />
    <meta name="theme-color" content="#141414" />
    <link rel="canonical" href={canonical} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content="https://climp.net/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:site_name" content="climp" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://climp.net/og-image.png" />

    <link
      rel="preload"
      href="/fonts/JetBrainsMono-Regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <a
      href="#install"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:bg-accent focus:text-bg focus:px-3 focus:py-1 focus:rounded"
    >
      Skip to install
    </a>
    <slot />
    <Analytics />
  </body>
</html>
